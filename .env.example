# Example env vars
# Only LLM is external. OCR uses local libraries (pytesseract/pdf2image/pdfminer).
LLM_API_URL=
LLM_API_KEY=
JOB_STORAGE_DIR=./data/jobs
ORIGINALS_DIR=./data/originals
DEFAULT_EXPIRY_MONTHS=6

# Notes:
# - Install Tesseract OCR (system package) and poppler for pdf2image.
#   macOS (Homebrew): brew install tesseract poppler
